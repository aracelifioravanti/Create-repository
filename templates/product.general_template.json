adding_bottom":36,"custom_colors_background":"#f3f3f3","custom_gradient_background":"","custom_colors_text":"#2e2a39","custom_colors_solid_button_background":"#ffffff","custom_colors_solid_button_text":"#b71cec","custom_colors_outline_button":"#34dd1d"}},"ds_vertical_ticker_fwgVf3":{"type":"ds-vertical-ticker","blocks":{"text_qNHq4H":{"type":"text","settings":{"title":"Up to 50% Off"}}},"block_order":["text_qNHq4H"],"settings":{"number_of_rows":6,"speed":3,"text_size":"3","italic_text":false,"uppercase_text":false,"bold_text":false,"ticker_color_scheme":"custom","layout":"ticker_second","padding_top":40,"padding_bottom":40,"display_content":"always","content_heading":"🛍️ Flash Sale Alert!","content_heading_size":"h2","content_text":"<p><strong>Stock Up on Freshness – Up to 50% Off!<\/strong><br\/>Organize your kitchen like never before with our best-selling food containers. For the next <strong>48 hours only<\/strong>, enjoy unbeatable discounts on our durable, BPA-free, and space-saving designs.<\/p>","button_label":"","link":"","button_style_secondary":false,"content_color_scheme":"background-1","overlay_color":"#ef7500","overlay_opacity":0,"content_padding_top":36,"content_padding_bottom":24,"custom_ticker_colors_background":"#ef7500","custom_ticker_gradient_background":"","custom_ticker_colors_text":"#ffffff","custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#ffffff","custom_colors_solid_button_background":"#ffffff","custom_colors_solid_button_text":"#ef7500","custom_colors_outline_button":"#dd1d1d"}},"ds_testimonials_i86BLn":{"type":"ds-testimonials","blocks":{"column_YyHMKP":{"type":"column","settings":{"title":"Great Prices and Fast Delivery","text":"<h5>I was impressed by how affordable and convenient GreenHaven Home & Garden is. I ordered a patio set and some potted plants online, and everything arrived quickly and in perfect condition. It’s refreshing to find a shop that offers both quality and value!<\/h5>","author":"Jessica L."}},"column_ENbtbz":{"type":"column","settings":{"title":"Knowledgeable Staff","text":"<h5>GreenHaven is my go-to for all my gardening needs. The staff is incredibly knowledgeable and always willing to offer tips on plant care and landscaping. Thanks to their advice, my garden looks better than ever! Will recommend it to everyone.<\/h5>","author":"Kate F."}},"column_Xj89MC":{"type":"column","settings":{"title":"Durable and Eco-Friendly","text":"<h5>I absolutely love shopping at GreenHaven Home & Garden! Their selection of plants, outdoor furniture, and home décor is unmatched. Everything I’ve purchased has been of the highest quality and has transformed my living space into a oasis. <\/h5>","author":"Tina M."}}},"block_order":["column_YyHMKP","column_ENbtbz","column_Xj89MC"],"settings":{"title":"Our Clients Say","heading_size":"h2","text":"","image_width":"full","image_ratio":"square","columns_desktop":3,"slider_preview":true,"column_alignment":"center","show_stars":false,"stars_color":"#ffd700","show_quotes":false,"quotes_color_scheme":"background-1","background_style":"primary","color_scheme":"background-1","padding_top":36,"padding_bottom":36,"custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#121212"}},"rich_text_6PCjaT":{"type":"rich-text","blocks":{"heading_cWpbbj":{"type":"heading","settings":{"heading":"","heading_size":"h1"}},"text_PiMGXq":{"type":"text","settings":{"text":"<p><strong>Premium Quality:<\/strong> Our product are crafted from BPA-free, food-grade materials, ensuring safety and durability.<\/p><p><strong>Sustainability First:<\/strong> We prioritize eco-friendly solutions, helping reduce single-use plastics with our reusable, long-lasting products.<\/p><p><strong>Innovation at Heart:<\/strong> Every product is designed with convenience in mind, from safe and friendly features to stackable designs that save valuable space.<\/p><p><strong>Customer-Centric:<\/strong> Your satisfaction is our priority. We are committed to providing excellent customer service and quality products that stand the test of time.<\/p>"}},"button_eCCWYQ":{"type":"button","settings":{"button_label":"","button_link":"","button_style_secondary":false,"button_label_2":"","button_link_2":"","button_style_secondary_2":false}}},"block_order":["heading_cWpbbj","text_PiMGXq","button_eCCWYQ"],"settings":{"desktop_content_position":"left","content_alignment":"left","color_scheme":"background-1","full_width":true,"padding_top":40,"padding_bottom":52,"custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#2e2a39","custom_colors_solid_button_background":"#dd1d1d","custom_colors_solid_button_text":"#ffffff"}}},"order":["related-products","main","collapsible_content_VV38cX","ds_comparison_table_xaDNwU","ds_vertical_ticker_fwgVf3","ds_testimonials_i86BLn","rich_text_6PCjaT"]}